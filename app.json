{
  "expo": {
    "name": "echo-app",
    "slug": "echo-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app-icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/app-splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#111315"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.echoapp"
    },
    "android": {
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-splash-icon.png",
        "backgroundColor": "#111315"
      },
      "package": "com.anonymous.echoapp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Geist-Bold.ttf",
            "./assets/fonts/Geist-Regular.ttf"
          ]
        }
      ],
      "expo-asset",

      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "La aplicación accede a tus fotos para permitirte compartirlas con tus amigos.",
          "cameraPermission": "La aplicación accede a tu cámara para permitirte tomar fotos y compartirlas con tus amigos.",
          "microphonePermission": "La aplicación accede a tu micrófono para permitirte grabar videos con sonido."
        }
      ],
      "./plugins/withFmtConsteval"
    ]
  }
}
